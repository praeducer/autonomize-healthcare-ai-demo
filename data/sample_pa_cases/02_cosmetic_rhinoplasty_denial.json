                }
              ]
            },
            "valueString": "Patient is a 34-year-old female requesting rhinoplasty. Patient desires improvement in nasal appearance. Reports dissatisfaction with dorsal hump and wide nasal tip. No history of nasal trauma. No complaints of nasal obstruction or breathing difficulty. No prior nasal surgery."
          },
          {
            "sequence": 2,
            "category": {
              "coding": [
                {
                  "system": "http://terminology.hl7.org/CodeSystem/claiminformationcategory",
                  "code": "info",
                  "display": "Information"
                }
              ]
            },
            "valueString": "Physical examination: External nasal deformity with dorsal hump. Bilateral nasal airways patent. No septal deviation noted on anterior rhinoscopy. No signs of actinic keratosis on nasal skin. Diagnosis of L57.0 appears unrelated to the requested procedure."
          }
        ]
      }
