            },
            "valueString": "45-year-old female with rheumatoid arthritis diagnosed 3 years ago. Currently experiencing moderate disease activity with symmetric polyarthritis involving MCPs, PIPs, wrists, and knees bilaterally. Morning stiffness lasting > 2 hours. Reports 'failed methotrexate' but dose, duration, and reason for discontinuation not documented."
          },
          {
            "sequence": 2,
            "category": {
              "coding": [
                {
                  "system": "http://terminology.hl7.org/CodeSystem/claiminformationcategory",
                  "code": "info",
                  "display": "Information"
                }
              ]
            },
            "valueString": "Requesting Humira (adalimumab) 40mg subcutaneous every 2 weeks. No laboratory results provided with this submission. DAS28 score not documented. No documentation of prior DMARD trial details. TB screening status unknown. No biosimilar consideration documented."
          }
        ]
      }
