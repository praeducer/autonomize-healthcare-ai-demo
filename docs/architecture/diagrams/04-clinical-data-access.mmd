flowchart TB
    subgraph "AI Engine"
        COPILOT["PA Copilot<br/>Clinical Data Request"]
    end

    subgraph "Clinical Data Aggregation"
        AGG["Aggregation Service<br/>Unified Clinical Context"]
    end

    subgraph "Modern Sources"
        FHIR_EP["FHIR R4 Endpoints<br/>OAuth 2.0 / SMART"]
        FHIR_RES["Patient, Encounter,<br/>Observation, DiagReport"]
    end

    subgraph "Legacy Sources"
        LEG_DB["Legacy Databases<br/>Service Account + VNet"]
        LEG_HL7["HL7 v2 Interfaces<br/>Secure Channel"]
    end

    subgraph "Security Boundary"
        TLS["TLS 1.2+ Encryption"]
        TOKEN["PHI Tokenization<br/>Before LLM Processing"]
        AUDIT_LOG["Access Audit Trail"]
    end

    COPILOT -->|"Patient ID + Context"| AGG
    AGG -->|"FHIR R4 REST API"| FHIR_EP
    FHIR_EP --> FHIR_RES
    AGG -->|"DB Connector"| LEG_DB
    AGG -->|"HL7 v2 Interface"| LEG_HL7
    FHIR_RES --> AGG
    LEG_DB --> AGG
    LEG_HL7 --> AGG
    AGG -->|"Unified Clinical Record"| TOKEN
